# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=1h

# ─── MySQL (Sequelize) ────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=secure_api_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# ─── MongoDB (Mongoose) ───────────────────────────────
MONGO_URI=mongodb://localhost:27017/secure_api_logs
